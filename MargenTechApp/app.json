{
  "expo": {
    "name": "Margen Technician",
    "slug": "margen-technician",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111827"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.margen.technician",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Margen Technician shares your location with dispatch while you are clocked in.",
        "NSPhotoLibraryUsageDescription": "Attach before and after photos to job records."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111827"
      },
      "package": "com.margen.technician",
      "edgeToEdgeEnabled": true,
      "permissions": ["ACCESS_COARSE_LOCATION", "ACCESS_FINE_LOCATION"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Margen Technician uses your location while clocked in (about once per minute)."
        }
      ],
      "expo-secure-store"
    ]
  }
}
