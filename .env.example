VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Optional: Google Maps JavaScript API (enable Maps JavaScript, Places, Geocoding).
# Used for technician map + Settings service-area (Places Autocomplete + coverage map).
# VITE_GOOGLE_MAPS_API_KEY=

# Invite links & QR codes (production)
# VITE_PUBLIC_SITE_URL=https://trymargen.com
# Synthetic auth email host for technicians (no mailbox; Supabase Auth only)
# VITE_INVITE_EMAIL_DOMAIN=invite.trymargen.com

# Shared Retell AI (Margen-managed account) — deploy AI Receptionist from the dashboard
# VITE_RETELL_API_KEY=

# Stripe — client subscription checkout (@stripe/stripe-js redirectToCheckout)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# VITE_STRIPE_STARTER_PRICE_ID=price_...
# VITE_STRIPE_GROWTH_PRICE_ID=price_...
# VITE_STRIPE_SCALE_PRICE_ID=price_...
# Optional separate annual recurring prices (10× monthly). If omitted, annual uses the monthly price ID.
# VITE_STRIPE_STARTER_PRICE_ID_ANNUAL=price_...
# VITE_STRIPE_GROWTH_PRICE_ID_ANNUAL=price_...
# VITE_STRIPE_SCALE_PRICE_ID_ANNUAL=price_...
# Success/cancel URLs use VITE_PUBLIC_SITE_URL when set, else window.location.origin. Add those domains in Stripe Dashboard → Checkout settings.

# Supabase Edge (webhook + billing portal + cancel): STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET,
# STRIPE_PRICE_STARTER, STRIPE_PRICE_GROWTH, STRIPE_PRICE_SCALE (same Price ID strings as VITE_* for webhook plan matching),
# optional STRIPE_PRICE_*_ANNUAL for annual rows, plus PUBLIC_SITE_URL / SITE_URL for other flows.
# Optional: extra dev emails (comma-separated) that skip paid-subscription gate — see src/lib/subscriptionAccess.ts
# VITE_DEV_BYPASS_EMAILS=

# Owner-pasted Stripe keys (Settings → analytics sync): set STRIPE_USER_KEY_ENCRYPTION_SECRET on Edge (long random
# string, min 16 chars) so keys are encrypted at rest before storage in stripe_analytics_credentials.
# Retell Edge Functions (e.g. test call) also accept RETELL_API_KEY as a Supabase secret (same key value).
#
# Twilio (Edge: provision-twilio-number, send-forwarding-sms, inbound voice) — set on Supabase:
# TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, TWILIO_FROM_NUMBER (E.164 for SMS)
# RETELL_TWILIO_INBOUND_WEBHOOK_URL — full Retell Twilio voice webhook URL for purchased numbers (Retell dashboard)
# PUBLIC_FUNCTIONS_BASE_URL — e.g. https://<ref>.supabase.co/functions/v1 (for Twilio status callbacks)
